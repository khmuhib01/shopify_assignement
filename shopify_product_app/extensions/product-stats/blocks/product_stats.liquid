<div id="react-product-stats" 
     data-product-id="{{ product.id }}" 
     data-api-url="{{ block.settings.api_url }}">
  <!-- React will render here -->
</div>

{{ 'product-stats-bundle.js' | asset_url | script_tag }}

<style>
  .shopify-product-stats-box {
    margin: 20px 0;
    padding: 15px;
    border: 1px solid #e1e1e1;
    border-radius: 8px;
    background-color: #f9f9f9;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }
</style>

<script>
  // Purchase Tracking (Add to Cart)
  (function() {
    const productId = "{{ product.id }}";
    const apiUrl = "{{ block.settings.api_url }}";
    
    const addToCartForm = document.querySelector('form[action$="/cart/add"]');
    if (addToCartForm) {
      addToCartForm.addEventListener('submit', function() {
        fetch(`${apiUrl}/api/product/purchase`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ product_id: productId })
        });
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Product Stats Box",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "api_url",
      "label": "Backend API URL",
      "default": "http://localhost:8000"
    }
  ],
  "presets": [
    {
      "name": "Product Stats Box"
    }
  ]
}
{% endschema %}
